{
	"name": "delacry/di",
	"description": "Compiled dependency injection container — fork of nette/di adding tag-based service identity, #[Inject(tag:)], NEON @Type#tag references, and array<string, T> bag-of-services autowire.",
	"keywords": ["di", "dic", "ioc", "factory", "compiled", "static", "tag"],
	"homepage": "https://github.com/rixafy/di",
	"license": ["BSD-3-Clause", "GPL-2.0-only", "GPL-3.0-only"],
	"authors": [
		{
			"name": "David Grudl",
			"homepage": "https://davidgrudl.com",
			"role": "Original author of nette/di"
		},
		{
			"name": "Delacry",
			"homepage": "https://github.com/delacry",
			"role": "Fork maintainer"
		},
		{
			"name": "Nette Community",
			"homepage": "https://nette.org/contributors",
			"role": "Original contributors to nette/di"
		}
	],
	"require": {
		"php": "8.4 - 8.5",
		"ext-tokenizer": "*",
		"ext-ctype": "*",
		"nette/neon": "^3.4",
		"nette/php-generator": "^4.1.6",
		"nette/robot-loader": "^4.0",
		"nette/schema": "^1.3",
		"nette/utils": "^4.0"
	},
	"replace": {
		"nette/di": "3.3.*"
	},
	"require-dev": {
		"nette/tester": "^2.6",
		"tracy/tracy": "^2.9",
		"phpstan/phpstan": "^2.1@stable",
		"phpstan/extension-installer": "^1.4@stable",
		"nette/phpstan-rules": "^1.0"
	},
	"autoload": {
		"classmap": ["src/"],
		"psr-4": {
			"Nette\\": "src"
		}
	},
	"minimum-stability": "dev",
	"scripts": {
		"phpstan": "phpstan analyse",
		"tester": "tester tests -s"
	},
	"extra": {
		"branch-alias": {
			"dev-master": "3.3-dev",
			"dev-main": "3.3.x-dev"
		}
	},
	"config": {
		"allow-plugins": {
			"phpstan/extension-installer": true
		}
	}
}
