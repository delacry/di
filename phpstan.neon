parameters:
	level: 8

	paths:
		- src

	reportUnmatchedIgnoredErrors: false

	fileExtensions:
		- php
		- phtml

	ignoreErrors:
		-
			identifier: return.type
			path: src/DI/Definitions/FactoryDefinition.php
		-
			identifier: instanceof.alwaysTrue
			path: src/DI/Definitions/ServiceDefinition.php
		-
			identifier: function.alreadyNarrowedType
			path: src/DI/Definitions/Statement.php
		-
			identifier: function.impossibleType
			path: src/DI/ContainerBuilder.php
		-
			identifier: argument.type
			path: src/DI/Extensions/ServicesExtension.php
		-
			identifier: property.notFound
			path: src/Bridges/DITracy/ContainerPanel.php
		-
			identifier: closure.unusedUse
			path: src/Bridges/DITracy/ContainerPanel.php
		-
			identifier: argument.type
			path: src/DI/Config/Adapters/NeonAdapter.php
		-
			identifier: instanceof.alwaysTrue
			path: src/DI/Extensions/ParametersExtension.php
		-
			identifier: identical.alwaysFalse
			path: src/DI/Autowiring.php
		-
			identifier: isset.offset
			path: src/DI/Autowiring.php
		-
			identifier: booleanAnd.alwaysFalse
			path: src/DI/Autowiring.php
		-
			identifier: nullCoalesce.offset
			path: src/DI/Autowiring.php
		- # template compiled with precise types, is_string always true
			identifier: function.alreadyNarrowedType
			path: src/Bridges/DITracy/dist/panel.phtml
		- # defensive guard against unexpected dependency types in the array union
			identifier: instanceof.alwaysTrue
			path: src/DI/DependencyChecker.php
		- # getByType() generic template limitation
			identifier: return.type
			path: src/DI/Container.php
		- # closure passes string to class-string params
			identifier: argument.type
			path: src/DI/Container.php
		- # callInjects passes array as callable
			identifier: argument.type
			path: src/DI/Extensions/InjectExtension.php
		- # generic callable invoker - signature varies by caller, no universal type
			identifier: missingType.callable
			path: src/DI/Container.php
		- # runtime-derived class name; class is loaded by load(), contract is class-string<Container>
			identifier: return.type
			path: src/DI/ContainerLoader.php
		- # string as class-string in various places
			identifier: argument.type
			path: src/DI/Resolver.php
		- # class_parents/class_implements key type
			identifier: offsetAccess.invalidOffset
			path: src/DI/Autowiring.php
		- # $this->$list assignment
			identifier: assign.propertyType
			path: src/DI/Autowiring.php
		- # string from array key used as class-string
			identifier: argument.type
			path: src/DI/Extensions/SearchExtension.php
		- # string from array key used as class-string
			identifier: argument.type
			path: src/DI/Extensions/DefinitionSchema.php
		- # constructor entity param deliberately broad (native array, no value type)
			identifier: missingType.iterableValue
			path: src/DI/Definitions/Statement.php
		- # promoted property stores broad array, getEntity() declares precise tuple
			identifier: return.type
			path: src/DI/Definitions/Statement.php
		- # exhaustive type check after precise getEntity() return type
			identifier: elseif.alwaysTrue
			path: src/DI/Config/Adapters/NeonAdapter.php
		- # array_values after unset not recognized as list
			identifier: assign.propertyType
			path: src/DI/Config/Adapters/NeonAdapter.php
		- # getByType template type unresolvable in closure
			identifier: argument.templateType
			path: src/DI/Container.php
		- # normalizeClass: ReflectionClass->name is string not class-string
			identifier: return.type
			path: src/DI/Helpers.php
		- # normalizeEntity: reference tracking defeats type narrowing
			identifier: return.type
			path: src/DI/Resolver.php
		- # string as class-string for ReflectionClass in canBeLazy
			identifier: argument.type
			path: src/DI/Definitions/ServiceDefinition.php
		- # string as class-string for ReflectionClass in calculateHash
			identifier: argument.type
			path: src/DI/DependencyChecker.php
		- # exportMeta complex return shape with optional keys
			identifier: return.type
			path: src/DI/ContainerBuilder.php
		- # addDefinition template type unresolvable
			identifier: argument.templateType
			path: src/DI/Extensions/ServicesExtension.php
		- # extension defines $config schema shape via phpDoc; default [] precedes Schema-populated object
			identifier: property.phpDocType
			paths:
				- src/DI/Extensions/DIExtension.php
				- src/DI/Extensions/DecoratorExtension.php
				- src/DI/Extensions/ParametersExtension.php
				- src/DI/Extensions/SearchExtension.php
		- # $config default [] before Schema processing populates the object
			identifier: property.defaultValue
			path: src/DI/Extensions/DIExtension.php
		- # anonymous class assigned to typed $config property
			identifier: assign.propertyType
			path: src/DI/Extensions/DIExtension.php
		- # stdClass property assignment in typed object shape
			identifier: assign.propertyReadOnly
			path: src/DI/Extensions/DecoratorExtension.php
		- # defensive array_filter on config entries
			identifier: arrayFilter.same
			path: src/DI/Extensions/SearchExtension.php
		- # findAutowired / findByType accept string for type, internal use
			identifier: argument.type
			path: src/Bridges/DITracy/ContainerPanel.php
		- # createLoader $params type is whatever the caller passes
			identifier: missingType.iterableValue
			path: src/DI/Compiler.php
		- # WeakMap generics omitted intentionally — populated dynamically
			identifier: missingType.generics
			path: src/DI/Config/Adapters/NeonAdapter.php
		- # @throws documents what callers see; not all branches throw it directly
			identifier: throws.unusedType
			path: src/DI/Config/Adapters/NeonAdapter.php
		- # NEON node chain arrays are heterogeneous by design
			identifier: missingType.iterableValue
			path: src/DI/Config/Adapters/NeonAdapter.php
		- # processClosure return type comes from user closure
			identifier: missingType.iterableValue
			path: src/DI/Config/Adapters/PhpAdapter.php
		- # processClosure $callback is deliberately a bare Closure (user-provided signature unknown)
			identifier: missingType.callable
			path: src/DI/Config/Adapters/PhpAdapter.php
		- # preg_replace accepts string|null in practice (null is treated as empty)
			identifier: argument.type
			path: src/DI/ContainerLoader.php
		- # Statement::$entity narrower phpDoc type, broad runtime accepts array
			identifier: assign.propertyType
			path: src/DI/Definitions/Statement.php
		- # PHP version probe — branch reachable on PHP < 8.3 (older runtimes), dead on 8.4+
			identifier: smaller.alwaysFalse
			path: src/DI/DependencyChecker.php
		- # PHP version probe — branch reachable on PHP >= 8.4, baseline assumption
			identifier: greaterOrEqual.alwaysTrue
			path: src/DI/Extensions/DIExtension.php
		- # Reflection::getUseStatements may return false on parse failure
			identifier: foreach.nonIterable
			path: src/DI/Helpers.php
